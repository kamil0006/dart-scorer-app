{
  "expo": {
    "name": "Dart Scorer",
    "slug": "dart-scorer",
    "version": "1.11.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dartscorer",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "package": "com.anonymous.dartscorer",
      "versionCode": 14
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-sharing"
    ]
  }
}
